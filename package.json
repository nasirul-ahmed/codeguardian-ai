{
  "name": "codeguardian-ai",
  "version": "1.0.0",
  "description": "CodeGuardian AI - Intelligent Pull Request Reviewer",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "ncc build src/index.js -o dist",
    "act": "act pull_request --secret-file .secrets",
    "format": "prettier --write \"src/**/*.{js,md}\""
  },
  "keywords": [
    "github-action",
    "code-review",
    "ai",
    "gpt-4",
    "automation"
  ],
  "author": "Nasirul Ahmed<nasirul369@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/github": "^5.1.1",
    "@heyputer/puter.js": "^2.2.10",
    "dotenv": "^17.3.1",
    "minimatch": "^9.0.3",
    "octokit": "^3.1.0",
    "openai": "^4.20.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@vercel/ncc": "^0.38.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "nock": "^13.5.6",
    "prettier": "3.8.1",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
